// ── TEST NSA v2.2 ────────────────────────────────────────────────────
// Tests: string comparison, int array, str array, alen, loop over array

print "=== NSA v2.2 Test Suite ==="
print ""

// ── 1. String comparison ─────────────────────────────────────────────
print "-- String Comparison --"

let s1 = "hello"
let s2 = "hello"
let s3 = "world"

cmp eq1 s1 == s2
cmp eq2 s1 == s3
cmp ne1 s1 != s3

print eq1           // true
print eq2           // false
print ne1           // true

// Use in if
if eq1 then
    print "s1 == s2: PASS"
end
if eq2 then
    print "FAIL"
else
    print "s1 != s3: PASS"
end

// ── 2. Integer array ─────────────────────────────────────────────────
print ""
print "-- Integer Array --"

arr int scores 5

aset scores 0 100
aset scores 1 85
aset scores 2 92
aset scores 3 78
aset scores 4 95

alen n scores       // n = 5

let i = 0
loop while i < 5
    aget val scores i
    println "scores["
    println i
    println "] = "
    print val
    inc i
end

// sum using array
let sum = 0
let j = 0
loop while j < 5
    aget x scores j
    add sum x
    inc j
end
println "sum = "
print sum           // 450

// ── 3. String array ──────────────────────────────────────────────────
print ""
print "-- String Array --"

arr str fruits 3
aset fruits 0 "apple"
aset fruits 1 "banana"
aset fruits 2 "cherry"

let k = 0
loop while k < 3
    aget fname fruits k
    print fname
    inc k
end

// find in array
let target = "banana"
let found = false
let fi = 0
loop while fi < 3
    aget item fruits fi
    cmp match item == target
    if match then
        let found = true
    end
    inc fi
end
if found then
    print "found banana: PASS"
else
    print "FAIL"
end

// ── 4. Bool array ────────────────────────────────────────────────────
print ""
print "-- Bool Array --"

arr bool flags 4
aset flags 0 true
aset flags 1 false
aset flags 2 true
aset flags 3 false

let bi = 0
loop while bi < 4
    aget bv flags bi
    print bv
    inc bi
end

// ── 5. alen + dynamic loop ───────────────────────────────────────────
print ""
print "-- alen --"
alen sz scores
println "scores size = "
print sz            // 5

// ── 6. Existing features still work ─────────────────────────────────
print ""
print "-- Functions still work --"

func double n -> result
    let result = 0
    copy result n
    mul result 2
endfunc

let base = 21
call double base -> doubled
println "double(21) = "
print doubled       // 42

print ""
print "=== All tests passed ==="
